generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TransactionType {
  Deposit
  Withdrawal
}

model Account {
  id             String        @id @default(uuid())
  name           String        @unique
  avatarUrl      String        @map("avatar_url") @db.Text
  currentBalance Decimal       @default(0) @map("current_balance") @db.Decimal(12, 2)
  themeColor     String        @default("#2F7DF6") @map("theme_color")
  profileColor   String        @default("#DCEBFF") @map("profile_color")
  profilePattern String        @default("soft") @map("profile_pattern")
  goalName       String?       @map("goal_name")
  goalAmount     Decimal?      @map("goal_amount") @db.Decimal(12, 2)
  pinHash        String        @default("9af15b336e6a9619928537df30b2e6a2376569fcf9d7e773eccede65606529a0") @map("pin_hash")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  transactions   Transaction[]

  @@map("accounts")
}

model Transaction {
  id        String          @id @default(uuid())
  accountId String          @map("account_id")
  account   Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date      DateTime        @default(now())
  type      TransactionType
  amount    Decimal         @db.Decimal(12, 2)
  reason    String?
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([accountId, date])
  @@map("transactions")
}

model HistoricalLedger {
  id           String   @id @default(uuid())
  date         DateTime @unique @db.Date
  basilBalance Decimal  @default(0) @map("basil_balance") @db.Decimal(12, 2)
  osamaBalance Decimal  @default(0) @map("osama_balance") @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("historical_ledgers")
}
